# Template — substitute DATA_PRIVATE_IP before sourcing on e2e-runner.
export CARGO_BUILD_JOBS=1
export RUST_BACKTRACE=1
export CHRONON_POSTGRES_URL=postgres://chronon:chronon@DATA_PRIVATE_IP:5432/chronon
export CHRONON_REDIS_URL=redis://DATA_PRIVATE_IP:6379
export CHRONON_NUM_PARTITIONS=4
export CHRONON_TICK_INTERVAL_MS=250
